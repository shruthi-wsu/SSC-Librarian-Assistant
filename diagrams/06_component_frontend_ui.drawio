    <!-- Service Layer sub-component -->
    <mxCell id="30" value="«component»&#xa;API Service Layer&#xa;(src/services/)&#xa;&#xa;authService.ts&#xa;  + login(email, pwd) : Promise&lt;JwtToken&gt;&#xa;  + register(dto) : Promise&lt;User&gt;&#xa;bookService.ts&#xa;  + searchBooks(query) : Promise&lt;Book[]&gt;&#xa;  + getBook(id) : Promise&lt;Book&gt;&#xa;checkoutService.ts&#xa;  + checkout(bookId) : Promise&lt;Checkout&gt;&#xa;  + returnBook(txId) : Promise&lt;void&gt;&#xa;holdService.ts&#xa;  + placeHold(bookId) : Promise&lt;Hold&gt;" style="shape=mxgraph.uml.component;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="870" y="90" width="240" height="280" as="geometry" />
    </mxCell>
    <mxCell id="31" value="depends on" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=1.5;dashed=1;endArrow=open;endFill=0;fontSize=10;" edge="1" parent="1" source="10" target="30">
