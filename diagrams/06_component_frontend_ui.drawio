    <!-- Attributes -->
    <mxCell id="11" value="— State / Attributes —&#xa;authToken : string (JWT, stored in localStorage)&#xa;currentUser : User | null&#xa;searchQuery : string&#xa;bookList : Book[]&#xa;userCheckouts : Checkout[]&#xa;userHolds : Hold[]" style="text;html=1;strokeColor=#6c8ebf;fillColor=#EEF4FF;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="230" y="135" width="580" height="110" as="geometry" />
    </mxCell>

    <!-- Pages / Operations -->
    <mxCell id="12" value="— Pages / Operations —&#xa;LoginPage: login(email, pwd) → POST /api/auth/login → store JWT            [FR-1]&#xa;RegisterPage: register(dto) → POST /api/auth/register                         [FR-1]&#xa;BookSearchPage: searchBooks(query) → GET /api/books/search                   [FR-2]&#xa;BookDetailPage: viewBook(id) → GET /api/books/{id}                           [FR-2]&#xa;                placeHold(bookId) → POST /api/holds                           [FR-3]&#xa;                checkoutBook(bookId) → POST /api/checkouts                    [FR-4]&#xa;DashboardPage: viewMyCheckouts() → GET /api/checkouts/user/{id}              [FR-4]&#xa;               returnBook(transactionId) → PUT /api/checkouts/{id}/return      [FR-5]&#xa;               viewReports() → GET /api/reports                               [FR-6]" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10.5;" vertex="1" parent="1">
      <mxGeometry x="230" y="250" width="580" height="195" as="geometry" />
    </mxCell>

    <!-- Shared Components sub-box -->
    <mxCell id="13" value="— Shared Components —&#xa;Navbar | BookCard | SearchBar | LoadingSpinner | ErrorAlert" style="text;html=1;strokeColor=#6c8ebf;fillColor=#EEF4FF;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="230" y="450" width="580" height="60" as="geometry" />
