    <!-- Tech stack note -->
    <mxCell id="50" value="Tech Stack: React 18 + TypeScript + Vite | Routing: react-router-dom | HTTP: Axios | State: React Context (AuthContext)" style="text;html=1;strokeColor=#6c8ebf;fillColor=#EEF4FF;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="220" y="535" width="600" height="35" as="geometry" />
    </mxCell>

    <!-- Design notes -->
    <mxCell id="60" value="Design Notes:&#xa;• High Cohesion: each page maps 1:1 to a user task (FR-1 through FR-6); service layer isolates HTTP concerns&#xa;• Controlled Coupling: pages depend only on service layer functions, not directly on axios or backend URLs&#xa;• API Service Layer as interface: mocking services in tests decouples UI from backend (QG-7 Testability)&#xa;• JWT stored in AuthContext — single source of truth; Navbar reads it for role-based menu rendering (QG-5 Security)&#xa;• React SPA enables rich UX without page reloads (QG-3 Usability); browser-based = no install required (QG-8 Portability)" style="text;html=1;strokeColor=#999999;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="30" y="590" width="840" height="105" as="geometry" />
    </mxCell>

  </root>
