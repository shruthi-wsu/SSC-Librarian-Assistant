    <!-- Design notes -->
    <mxCell id="90" value="Design Notes:&#xa;• High Cohesion: single responsibility — all checkout/return/renewal operations in one component&#xa;• Controlled Coupling: depends on 3 repos + 2 services; interfaces keep dependencies explicit&#xa;• validateEligibility() enforces business rules centrally (max checkouts, suspended accounts)&#xa;• notifyNextInQueue() after return ensures seamless hold queue progression (FR-3 + FR-5 integration)&#xa;• calculateFine() isolated for independent unit testing (QG-7 Testability)" style="text;html=1;strokeColor=#999999;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="30" y="570" width="760" height="100" as="geometry" />
    </mxCell>

