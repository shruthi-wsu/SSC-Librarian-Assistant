    <!-- Design notes -->
    <mxCell id="60" value="Design Notes:&#xa;• High Cohesion: all operations relate to book catalog management (CRUD + search)&#xa;• Controlled Coupling: depends on BookRepository and notifies CirculationService on availability change&#xa;• IBookService interface allows mock injection in unit tests (supports QG-7 Maintainability)&#xa;• Pagination on searchBooks() supports QG-4 Performance (avoid loading entire catalog)" style="text;html=1;strokeColor=#999999;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="30" y="520" width="680" height="90" as="geometry" />
    </mxCell>

